# Cloudflare credentials — TEMPLATE (this .example file IS committed; do not put real values here).
#
# Setup:
#   1. cp .cloudflare.env.example .cloudflare.env
#   2. Paste your real token into .cloudflare.env (that file is gitignored).
#   3. Load it in a shell when you need it:  set -a; source .cloudflare.env; set +a
#
# Create a token at: https://dash.cloudflare.com/profile/api-tokens
# For DNS on keb.is / peterparkour.co, the "Edit zone DNS" template is enough
# (Permissions: Zone › DNS › Edit, scoped to the specific zone).

# Scoped API token (preferred over the global API key).
CLOUDFLARE_API_TOKEN=

# Account ID (Cloudflare dashboard → right sidebar / Account Home URL).
CLOUDFLARE_ACCOUNT_ID=

# Zone ID for the domain (dashboard → the domain → Overview → API section).
CLOUDFLARE_ZONE_ID=
